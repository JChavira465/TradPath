{
  "name": "tradpath",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "npm run generate --workspace=@tradpath/database",
    "db:push": "npm run db:push --workspace=@tradpath/database",
    "db:seed": "npm run db:seed --workspace=@tradpath/database"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "tar": "^7.5.19",
    "picomatch": "^4.0.5",
    "postcss": "^8.5.16",
    "uuid": "^14.0.1",
    "file-type": "^22.0.1"
  },
  "allowScripts": {
    "@nestjs/core@10.4.22": true,
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true,
    "bcrypt@5.1.1": true,
    "esbuild@0.28.1": true,
    "msgpackr-extract@3.0.4": true,
    "prisma@5.22.0": true
  }
}
