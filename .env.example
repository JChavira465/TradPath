# ─── App ───────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002
API_URL=http://localhost:3001

# ─── Database (Supabase Postgres) ──────────────────────
# Pooled connection (via PgBouncer) — used by the app at runtime
DATABASE_URL="postgresql://postgres:password@localhost:5432/tradpath?pgbouncer=true"
# Direct connection — used by Prisma Migrate / db push
DIRECT_URL="postgresql://postgres:password@localhost:5432/tradpath"

# ─── Supabase ───────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET_PUBLIC=tradpath-uploads
SUPABASE_STORAGE_BUCKET_PRIVATE=tradpath-uploads-private

# ─── Redis (Upstash, TLS) ───────────────────────────────
# Local dev: redis://localhost:6379
# Production: rediss://default:<password>@<host>:<port>
REDIS_URL=redis://localhost:6379

# ─── Auth / Tokens ──────────────────────────────────────
# Minimum 32 characters — app refuses to boot otherwise
JWT_SECRET=replace-with-a-random-64-char-hex-string-min-32-chars
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=30d
MFA_CHALLENGE_TOKEN_TTL=5m
COOKIE_SECRET=replace-with-a-random-64-char-hex-string-min-32-chars
REFRESH_COOKIE_NAME=refresh_token
ADMIN_REFRESH_COOKIE_NAME=admin_refresh

# MFA secret encryption — AES-256-GCM key, 32 bytes hex (64 hex chars)
MFA_ENCRYPTION_KEY=replace-with-a-64-char-hex-string-32-bytes

# ─── Stripe ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ─── Twilio ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# ─── SendGrid ───────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@tradpath.com
SENDGRID_FROM_NAME=TradPath

# ─── OpenAI ─────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Google Maps ────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── Cloudflare Turnstile ───────────────────────────────
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ─── Web apps (public) ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Used by apps/admin to open the owner dashboard for impersonation handoff
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# ─── Mobile (Expo) ──────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3001
